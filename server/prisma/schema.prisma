generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  full_name     String?
  // Platform-level privileges. `user` has none; `support` and `superadmin`
  // access the super-admin dashboard.
  role          Role      @default(user)
  // If set, the user IS the admin of that company (one admin per company).
  company_id    String?
  last_login_at DateTime?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  sessions      Session[]
  admin_of      Company?  @relation("CompanyAdmin", fields: [company_id], references: [id], onDelete: SetNull)

  @@index([company_id])
}

enum Role {
  user
  support
  superadmin
}

model Session {
  id         String   @id @default(cuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model MagicToken {
  id         String    @id @default(cuid())
  token      String    @unique
  email      String
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([email])
}

// ============================================================
// TENANT (Company)
// ============================================================

model Company {
  id                 String   @id @default(cuid())
  company_name       String
  email              String   @unique
  logo_url           String?
  brand_color        String?  @default("#000000")
  purchased_urls     Int      @default(0)
  used_urls          Int      @default(0)
  status             String   @default("active")
  stripe_customer_id String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  urls          Url[]
  profiles      Profile[]
  hardwareCards HardwareCard[]
  leads         Lead[]
  purchases     Purchase[]
  templates     Template[]
  teams         Team[]
  webhooks      Webhook[]
  audit_logs    AuditLog[]
  admins        User[]        @relation("CompanyAdmin")

  @@index([email])
}

// ============================================================
// URL — PERMANENT. Never changes. Decoupled from person/profile.
// ============================================================

model Url {
  id                 String   @id @default(cuid())
  company_id         String
  short_code         String   @unique
  qr_code_url        String?
  is_active          Boolean  @default(true)
  active_profile_id  String?  @unique
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  company         Company           @relation(fields: [company_id], references: [id], onDelete: Cascade)
  active_profile  Profile?          @relation("UrlActiveProfile", fields: [active_profile_id], references: [id], onDelete: SetNull)
  assignments     UrlAssignment[]
  hardware_cards  HardwareCard[]
  interactions    Interaction[]
  leads           Lead[]

  @@index([company_id])
  @@index([short_code])
}

// ============================================================
// PROFILE — The person's data. Mutable. Replaced on reassignment.
// ============================================================

model Profile {
  id              String   @id @default(cuid())
  company_id      String
  template_id     String?
  team_id         String?
  full_name       String?
  title           String?
  company_name    String?
  phone           String?
  email           String?
  bio             String?  @db.Text
  photo_url       String?
  social_links    Json?
  messaging_links Json?
  template        String?  @default("modern")
  font_style      String?  @default("sans")
  custom_color    String?  @default("#000000")
  lead_capture_enabled Boolean @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  company     Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  template_ref Template? @relation(fields: [template_id], references: [id], onDelete: SetNull)
  team        Team?     @relation(fields: [team_id], references: [id], onDelete: SetNull)
  active_url  Url?      @relation("UrlActiveProfile")
  leads       Lead[]

  @@index([company_id])
  @@index([template_id])
  @@index([team_id])
}

// ============================================================
// TEAM — Organizational subdivision inside a Company (Ventas, Marketing, etc.)
// ============================================================

model Team {
  id             String   @id @default(cuid())
  company_id     String
  name           String
  parent_team_id String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  parent   Team?     @relation("TeamTree", fields: [parent_team_id], references: [id], onDelete: SetNull)
  children Team[]    @relation("TeamTree")
  profiles Profile[]

  @@index([company_id])
  @@index([parent_team_id])
}

// ============================================================
// AUDIT LOG — Immutable record of critical actions.
// ============================================================

model AuditLog {
  id            String   @id @default(cuid())
  company_id    String
  actor_user_id String?
  actor_email   String?
  action        String   // e.g. url.reassigned, template.applied, lead.captured, csv.imported
  entity_type   String?  // url, profile, template, lead, webhook...
  entity_id     String?
  metadata      Json?
  created_at    DateTime @default(now())

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([company_id, created_at])
  @@index([action])
}

// ============================================================
// WEBHOOK — Outbound HTTP callback triggered on events.
// ============================================================

model Webhook {
  id         String   @id @default(cuid())
  company_id String
  name       String
  url        String   @db.Text
  secret     String?
  events     Json     // array of event strings, e.g. ["lead.captured"]
  is_active  Boolean  @default(true)
  last_fired_at DateTime?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  company    Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([company_id])
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhook_id   String
  event        String
  payload      Json
  status_code  Int?
  response     String?  @db.Text
  error        String?  @db.Text
  delivered_at DateTime @default(now())

  webhook Webhook @relation(fields: [webhook_id], references: [id], onDelete: Cascade)

  @@index([webhook_id, delivered_at])
}

// Smart Template — enforces brand/edit rules across a group of profiles.
model Template {
  id              String   @id @default(cuid())
  company_id      String
  name            String
  // Shared across every profile using this template (corporate website, linkedin, etc.)
  common_links    Json?
  // Array of profile field names that members cannot edit (admin-locked).
  locked_fields   Json?
  // Visual defaults: { template, font_style, custom_color }
  design_settings Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  company  Company   @relation(fields: [company_id], references: [id], onDelete: Cascade)
  profiles Profile[]

  @@index([company_id])
}

// ============================================================
// URL ASSIGNMENT — Audit trail of which profile a URL pointed to.
// ============================================================

model UrlAssignment {
  id               String    @id @default(cuid())
  url_id           String
  profile_snapshot Json       // archived profile fields at time of unassignment
  assigned_at      DateTime
  unassigned_at    DateTime?
  created_at       DateTime  @default(now())

  url Url @relation(fields: [url_id], references: [id], onDelete: Cascade)

  @@index([url_id])
}

// ============================================================
// HARDWARE CARD — Physical metallic NFC card. Re-printable per URL.
// ============================================================

model HardwareCard {
  id           String       @id @default(cuid())
  company_id   String
  url_id       String?
  nfc_uid      String?      @unique
  batch_number String?
  status       HardwareStatus @default(inventory)
  shipped_at   DateTime?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt

  company Company @relation(fields: [company_id], references: [id], onDelete: Cascade)
  url     Url?    @relation(fields: [url_id], references: [id], onDelete: SetNull)

  @@index([company_id])
  @@index([url_id])
}

enum HardwareStatus {
  inventory
  assigned
  shipped
  lost
  replaced
}

// ============================================================
// INTERACTION — One row per QR/NFC tap or profile view.
// ============================================================

model Interaction {
  id           String   @id @default(cuid())
  url_id       String
  timestamp    DateTime @default(now())
  // view | vcard_download | link_click | lead_captured
  event        String   @default("view")
  ip_address   String?
  user_agent   String?  @db.Text
  device_type  String?
  browser      String?
  os           String?
  referrer     String?  @db.Text
  geo_country  String?
  geo_city     String?
  geo_region   String?
  // Free-form payload: for link_click carries { target, url }; for vcard_download carries nothing.
  meta         Json?

  url Url @relation(fields: [url_id], references: [id], onDelete: Cascade)

  @@index([url_id])
  @@index([timestamp])
  @@index([event])
}

// ============================================================
// LEAD — Captured contact from Lead Capture Mode.
// ============================================================

model Lead {
  id          String   @id @default(cuid())
  url_id      String
  profile_id  String?
  company_id  String
  name        String?
  email       String?
  phone       String?
  company     String?
  notes       String?  @db.Text
  // Sales pipeline: new → contacted → qualified → closed_won | closed_lost
  status      String   @default("new")
  captured_at DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  url            Url      @relation(fields: [url_id], references: [id], onDelete: Cascade)
  profile        Profile? @relation(fields: [profile_id], references: [id], onDelete: SetNull)
  company_rel    Company  @relation(fields: [company_id], references: [id], onDelete: Cascade)

  @@index([url_id])
  @@index([company_id])
}

// ============================================================
// BILLING
// ============================================================

model Purchase {
  id                    String   @id @default(cuid())
  company_id            String?
  plan_id               String?
  plan_name             String?
  customer_name         String?
  customer_email        String?
  invoice_number        String?
  amount                Float
  url_count             Int
  stripe_session_id     String?
  stripe_payment_intent String?
  status                String   @default("pending")
  purchase_type         String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt
  company               Company? @relation(fields: [company_id], references: [id], onDelete: SetNull)

  @@index([customer_email])
  @@index([stripe_session_id])
}

model PricingPlan {
  id          String   @id @default(cuid())
  name        String
  price       Float
  url_count   Int
  description String?  @db.Text
  features    Json?
  is_active   Boolean  @default(true)
  sort_order  Int      @default(0)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}
